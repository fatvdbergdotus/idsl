	@Check // whether all the names used in a scenario are unique
	def checkUniqueItems (Scenario s){ // 
		if(IdslConfiguration.Lookup_value("check_for_double_names")=="false") return // quit checking 
		
		var List<String> merge_list = list_of_names(s)
		var Set<String> merge_set = new HashSet(merge_list)
		var Set<String> duplicate_set = new HashSet() // to be filled with duplicate variable names

		System.out.println("Scenario"+s.toString+" "+merge_list.toString) // for debugging

		for(elem:merge_set)
			if (Collections.frequency(merge_list, elem)>1) // found a duplicate
				duplicate_set.add(elem)
		
		if (duplicate_set.length>0)
			error("Scenario" +s.name.head+ " contains the following multiply used variable names: "+duplicate_set.toString,null)
		else
			info2("Scenario" +s.name.head+ " does not contain duplicate variable names",null)	 			
	}

	
	@Check // checks whether the names used in a service are unique
	def checkUniqueItems (Service s){ 
		if(IdslConfiguration.Lookup_value("check_for_double_names")=="false") return // skip checking
	
		var List<String> merge_list = list_of_names(s)
		var Set<String> merge_set = new HashSet(merge_list)
		var Set<String> duplicate_set = new HashSet() // to be filled with duplicate variable names

		System.out.println("Service"+s.toString+" "+merge_list.toString) // for debugging

		for(elem:merge_set)
			if (Collections.frequency(merge_list, elem)>1) // found a duplicate
				duplicate_set.add(elem)
		
		if (duplicate_set.length==0)
			info2("Service" +s.name+ " does not contain duplicate variable names",null)	 
		else
			error("Service "+s.name+" contains the following multiply used variable names: "+duplicate_set.toString,null)		
	}

	def List<String> list_of_names(Scenario s){
		var List<String> ret_list = new ArrayList()
		var Set<ResourceModel> resources = new HashSet() // resource model may overlap
		for(serv:s.ainstance){
			ret_list.addAll(list_of_names(serv.activity_id.head.extprocess_id))
			resources.add(serv.activity_id.head.resource_id)
		}
		for(res:resources)
			ret_list.addAll(list_of_names(res))
		
		//System.out.println("Scenario"+s.toString+" "+ret_list.toString) // for debugging
		return ret_list
	}

	def List<String> list_of_names(Service s){
		var List<String> ret_list = new ArrayList()	
		ret_list.addAll(list_of_names(s.extprocess_id))
		ret_list.addAll(list_of_names(s.resource_id))
		return ret_list	
	}
	
	def List<String> list_of_atomicprocess_names(ExtendedProcessModel epm){
		var List<String> ret_list = new ArrayList()
		ret_list.addAll(list_of_atomicprocess_names(epm.pmodel.head))
		for(el:epm.spm)
			ret_list.addAll(list_of_atomicprocess_names(el.pmodel.head))
		return ret_list			
	}
	
	def List<String> list_of_atomicprocess_names(ProcessModel pm){
		var List<String> ret_list = new ArrayList()
		switch(pm) { AtomicProcessModel:   if(pm.name!=null) ret_list.add(pm.name) } 
	
		switch(pm){ // recursively adds the subprocesses
 			ParProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))
			AltProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))
			SeqProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))
			PaltProcessModel:				for(el:pm.ppmodel) ret_list.addAll(list_of_atomicprocess_names(el.pmodel.head))
			MutexProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))
			SeqParProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))	
			LoadBalancerProcessModel:		for(el:pm.pmodel) ret_list.addAll(list_of_atomicprocess_names(el))			
		}
		return ret_list		
	}
	
	def boolean contains_load_balancer (ProcessModel pm){
		switch(pm){ // recursive function
 			ParProcessModel:				for(el:pm.pmodel)  if(contains_load_balancer(el)) return true
			AltProcessModel:				for(el:pm.pmodel)  if(contains_load_balancer(el)) return true
			SeqProcessModel:				for(el:pm.pmodel)  if(contains_load_balancer(el)) return true
			PaltProcessModel:				for(el:pm.ppmodel) if(contains_load_balancer(el.pmodel.head)) return true
			MutexProcessModel:				for(el:pm.pmodel)  if(contains_load_balancer(el)) return true
			SeqParProcessModel:				for(el:pm.pmodel)  if(contains_load_balancer(el)) return true	
			LoadBalancerProcessModel:		for(el:pm.pmodel)  return true			
		}
		return false		
	}

