	def List<String> list_of_names(ResourceTree rt){
		var List<String> ret_list = new ArrayList()
		switch(rt){
			AtomicResourceTree:   ret_list.add(rt.name)
			CompoundResourceTree: if(rt.name!=null) ret_list.add(rt.name)
		}
		switch(rt){ CompoundResourceTree: for(sub_rt:rt.rtree) ret_list.addAll(list_of_names(sub_rt)) } // recursion
		return ret_list
	}
	
	// **************** Check wheter the references that are used in utility functions are valid
	@Check
	def validUtilityReference (Model model){
		var measurements = model.experiment
		var utils = model.result.head.utils
		var services = model.amodel

		for(util:utils)
			validUtilityReference(util.util_func, measurements, services)
	}
	
	def void validUtilityReference (UExp uexp, List<Measurement> measurements, List<Service> services){
		switch (uexp){
			UExpExpr: 					{ validUtilityReference(uexp.a1.head, measurements, services) 
										  validUtilityReference(uexp.a2.head, measurements, services)}
			UExpAggregatedMeasurement:  validUtilityReference(uexp.measure.head, measurements, services)
			UExpFuncServiceRequest: 	validUtilityReference(uexp, measurements, services)
			UExpFuncUpperBound:			validUtilityReference(uexp, measurements, services)
			UExpFuncLowerBound:			validUtilityReference(uexp, measurements, services)
			UExpFuncUtilization:		validUtilityReference(uexp, measurements, services)
		}
	}

	def void validUtilityReference (UExpFuncServiceRequest uexp_fsr, List<Measurement> measurements, List<Service> services){
		if (!serviceStringInServiceList (uexp_fsr.service.str, services)) 	error ("Service "+uexp_fsr.service.str+" is not defined", null)
		if (!measurementSimulationInMeasurements(measurements)) 			error ("Latency is used, but no MeasurementSimulationInMeasurements measure defined",null)	
		
		var runs=uexp_fsr.runs
		switch(runs){
			UExpParameterInt: 			if (runs.int12>measurementSimulationRuns(measurements))		error ("The latency queries runs with too high numbers",null)
			UExpParameterTrueIntRange:  if (runs.int2>measurementSimulationRuns(measurements))		error ("The latency queries runs with too high numbers",null)
		}
		
		var reqno=uexp_fsr.requestno
		switch(reqno){
			UExpParameterInt: 			if (reqno.int12>measurementSimulationRequests(measurements))	error("The latency queries requests with too high numbers",null)	
			UExpParameterTrueIntRange:  if (reqno.int2>measurementSimulationRequests(measurements))		error("The latency queries requests with too high numbers",null)
		}
	}

	def void validUtilityReference (UExpFuncUpperBound uexp_fub, List<Measurement> measurements, List<Service> services){
		if (!serviceStringInServiceList (uexp_fub.service.str, services))	error ("Service "+uexp_fub.service.str+" is not defined", null)
		if (!measurementTheoBoundsInMeasurements(measurements))				error ("Upper bound is used, but no TheoBoundsInMeasurements measure defined",null)			
	}

	def void validUtilityReference (UExpFuncLowerBound uexp_flb, List<Measurement> measurements, List<Service> services){
		if (!serviceStringInServiceList (uexp_flb.service.str, services))	error ("Service "+uexp_flb.service.str+" is not defined", null)			
		if (!measurementTheoBoundsInMeasurements(measurements))				error ("Lower bound is used, but no TheoBoundsInMeasurements measure defined",null)			
	}

	def void validUtilityReference (UExpFuncUtilization uexp_fu, List<Measurement> measurements, List<Service> services){
		if (!measurementSimulationInMeasurements(measurements))				error ("Utility is used, but no MeasurementSimulationInMeasurements measure defined",null)
		// DISABLED!!! because it does not work right:  if(!resourceStringInServiceList(uexp_fu.resource.str,services))		error ("Resource "+uexp_fu.resource.str+" is not defined", null)
		
		var runs=uexp_fu.runs
		switch(runs){
			UExpParameterInt: 			if (runs.int12>measurementSimulationRuns(measurements))		error ("The utility queries runs with too high numbers",null)
			UExpParameterTrueIntRange:  if (runs.int2>measurementSimulationRuns(measurements))		error ("The utility queries runs with too high numbers",null)
		}

	}
	
	def serviceStringInServiceList (String service, List<Service> services){
		for (s:services)
			if (s.name==service)
				return true
		return false
	}
	
	def resourceStringInServiceList (String resource, List<Service> services){
		for (s:services)
			if (s.resource_id==resource)
				return true
		return false		
	}
	
	def measurementSimulationRuns(List<Measurement> measurements){
		for(m:measurements)
			switch(m){ MeasurementSimulation: return m.num_runs }
		return -1
	}

	def measurementSimulationRequests(List<Measurement> measurements){
		for(m:measurements)
			switch(m){ MeasurementSimulation: return m.num_activityis }
		return -1
	}
	
	def measurementSimulationInMeasurements(List<Measurement> measurements){
		for(m:measurements)
			switch(m){ MeasurementSimulation: return true }
		return false
	}
	
	def measurementTheoBoundsInMeasurements(List<Measurement> measurements){
		for(m:measurements)
			switch(m){ MeasurementTheoBounds: return true }
		return false		
	}
	
