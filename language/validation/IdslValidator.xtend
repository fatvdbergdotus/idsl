	@Check // Each process of the processModel exactly once in the mapping
	def each_process_once_in_the_mapping_of_service (Service service){
		var Set<String> atomic_procs 		= list_of_atomicprocess_names(service.extprocess_id).toSet
		var Set<String> procs 				= list_of_names(service.extprocess_id).toSet
		var Set<String> procs_in_map 		= new HashSet<String>
		
		for(proc_res:service.mapping.head.prassignment)
				procs_in_map.add(proc_res.process)
		
		var Set<String> undefined   = new HashSet<String> (atomic_procs)
		undefined.removeAll(procs_in_map)
		
		// TODO: IDEALLY YOU CHECK WHETHER THE PROCESS TREE COMPLETELY CONNECTS TO A MAPPING
		//if(undefined.size>0)
		//	warning2("Atomic processes "+undefined.toString+" are part of the process, but not defined in the mapping.",null)		
		
		var Set<String> overdefined = new HashSet<String> (procs_in_map)
		overdefined.removeAll(procs)
		if(overdefined.size>0)
			warning2("Processes "+overdefined.toString+" are defined in the mapping, but are not part of the process.",null)
	}
	
	@Check // Check for double, unambiqously defined processes in the mapping
	def each_process_in_mapping_unique(Mapping mapping){
		var Set<String> amb_procs = new HashSet<String>
		var prs = mapping.prassignment
		for(pr1:prs)
			for(pr2:prs)
				if(pr1.process==pr2.process && pr1.resource!=pr2.resource) // ambiguity/contradiction
					amb_procs.add(pr1.process)
					
		if (amb_procs.length>0)
			error("Processes "+amb_procs.toString+" are ambigously defined.",null)
	}
	
	@Check // Check whether for each resources all scheduling policies and time slicings are the same
	def equal_scheduling_policies_and_time_slices_per_resource(Model model){
		var serv_list = model.amodel
		var sched_policies = schedule_policies_per_system(serv_list)
		
		// compare scheduling policies in a 2D fashion
		for(sched_pol1:sched_policies)for(sched_pol2:sched_policies)
			compare_res_sched_policies(sched_pol1, sched_pol2)
	}
	
	def schedule_policies_per_system(List<Service> service_list){
		var List<ResourceSchedulingPolicy> schedpol_list = new ArrayList<ResourceSchedulingPolicy>
		for(serv:service_list)
			schedpol_list.addAll(serv.mapping.head.rspolicy)	
		return schedpol_list
	}
	
	def compare_res_sched_policies(ResourceSchedulingPolicy sched_pol1, ResourceSchedulingPolicy sched_pol2){
		if (sched_pol1.resource==sched_pol2.resource){ 
			if (IdslConfiguration.Lookup_value("Debug_mode")=="true"){
				System.out.println(sched_pol1.resource+" AND "+sched_pol1.resource)
				System.out.println(sched_pol1.policy.toString+" AND "+sched_pol1.policy.toString)
				System.out.println(sched_pol1.timeslice.toString+" AND "+sched_pol1.timeslice.toString)
			}
			
			if (!compare_sched_policy(sched_pol1.policy, sched_pol2.policy))
				error("Scheduling policy of resource "+sched_pol1.resource+" is defined ambiguously",null)
			if (!compare_time_slice(sched_pol1.timeslice, sched_pol2.timeslice))
				error("Time slicing of resource "+sched_pol1.resource+" is defined ambiguously",null)
		}
	}
	
	def boolean compare_sched_policy(SchedulingPolicy s1, SchedulingPolicy s2){
		switch(s1){
			SchedulingPolicyNonDet: switch(s2){ SchedulingPolicyNonDet: return true  default: return false}
			SchedulingPolicyFIFO:	switch(s2){ SchedulingPolicyFIFO:	return true  default: return false}
			default: return false
		}
	}
	
	def boolean compare_time_slice(TimeSlice t1, TimeSlice t2){
		var time1=t1.time
		var time2=t2.time
		
		// one of the values is null (non-preemption)
		if (time1==null && time2==null ) return true   		// both null
		else if (time1==null || time2==null ) return false  // one null		
		return IdslGeneratorExpression.equalsAExp(time1, time2)
	}

