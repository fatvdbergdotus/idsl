			AtomicProcessModel:				if(pm.name!=null) ret_list.add(pm.name) 	// more than 1 call to a specific piece of hardware is allowed
 			ParProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			AltProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			SeqProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			PaltProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			MutexProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			SeqParProcessModel:				if(pm.name!=null) ret_list.add(pm.name)
			LoadBalancerProcessModel:		if(pm.name!=null) ret_list.add(pm.name)	
		}
		switch(pm){ // recursively adds the subprocesses
 			ParProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
 			LoadBalancerProcessModel:		for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
			AltProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
			SeqProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
			PaltProcessModel:				for(el:pm.ppmodel) ret_list.addAll(list_of_names(el.pmodel.head))
			MutexProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
			SeqParProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el))
			DesAltProcessModel:				for(el:pm.pmodel) ret_list.addAll(list_of_names(el.pmodel.head)) 				
		}
		//System.out.println("PM  "+pm.toString+" "+ret_list.toString) // for debugging
		return ret_list
	}

