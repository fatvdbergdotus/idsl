	// ******************************* BOOLEAN EXPRESSION: validate whether the used dspaces all exist **********************************************************
	def List<String> boolExpUsesDspace (BExp b){
		var ret = new ArrayList<String>
		switch(b){
			BExpTrue:  			return ret
			BExpFalse: 			return ret
			BExpCmpString:		{ret.addAll(boolExpUsesDspace(b.bexpds_left.head))
								 ret.addAll(boolExpUsesDspace(b.bexpds_right.head))
								 return ret}
			BExpBi:				{ret.addAll(boolExpUsesDspace(b.bexp_left.head))
								 ret.addAll(boolExpUsesDspace(b.bexp_right.head))
								 return ret}
			BExpNeg:			return (boolExpUsesDspace(b.bexp.head)) 
			//BExpFile:			throw new Throwable("boolExpUsesDspace: Validation for file not implemented yet")
			default: 			throw new Throwable("boolExpUsesDspace: Something not implemented yet")
		}
	}

	def List<String> boolExpUsesDspace (BExpValue b){
		var ret = new ArrayList<String>	
		switch(b){
			BExpString:			return ret
			BExpDspace:			{ret.add(b.param.head)
								 return ret}
			BExpArithmetic:		{ ret.addAll(boolExpUsesDspace(b.bval_left.head))
								  ret.addAll(boolExpUsesDspace(b.bval_right.head))
								  return ret }
		}
	}
	
	@Check 
	def schedulingPolicyDefinedForValidResource (Model model) {
		var resources = model.eAllContents.toIterable.filter(typeof(AtomicResourceTree)).toList
		var mappings  = model.eAllContents.toIterable.filter(typeof(Mapping)).toList
		for(mapping:mappings)
			schedulingPolicyDefinedForValidResource(mapping, resources.map[i | i.name ])
	}
	
	def schedulingPolicyDefinedForValidResource (Mapping mapping, List<String> resources){
		for(pol:mapping.rspolicy){
			if (!resources.contains(pol.resource.toString))
				error("Resource "+pol.resource.toString+" is used in the policy but not defined in the resource section.", null)
		}
	}
	
	@Check
	def useOfValidDspacesInboolExp (Model model){
		var bexpconstraints = model.eAllContents.toIterable.filter(typeof(BExpconstraint)).toList 
		var dsms = model.eAllContents.toIterable.filter(typeof(DesignSpaceModel)).toList
		
		for(dsm:dsms)
			for(bexpconstraint:bexpconstraints){
				var List<String> dsm_params 	= params_of_DSM(dsm)
				var List<String> bexp_params	= boolExpUsesDspace(bexpconstraint.bexp.head)
				System.out.println(dsm_params)
				System.out.println(bexp_params)
				
				for(bexp_param:bexp_params)
					if (!dsm_params.contains(bexp_param) && bexp_param!="sampling_method") 
						warning2("Boolean constraints rely on "+bexp_param+", which the design space does not contain",null)
			} 	
	}
	
